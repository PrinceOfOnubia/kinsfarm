DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_KINSCLUB_CA=""

# Reward worker. Run with DRY_RUN=true first.
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
TREASURY_SECRET_KEY="base58-private-key-directly-or-[1,2,3,...,64]"
HOLDER_MINT="KINSCLUB_TOKEN_MINT"
REWARD_MINT="KINS_TOKEN_MINT"
PUMPPORTAL_API_KEY=""
DRY_RUN="true"
WORKER_CYCLE_SECONDS="600"
MIN_CLAIM_SOL="0.02"
RESERVE_SOL="0.03"
BUY_SLIPPAGE="12"
PRIORITY_FEE="0.00008"
MIN_HOLDER_BALANCE="500000"
TRANSFERS_PER_TX="8"
EXCLUDED_WALLETS=""
